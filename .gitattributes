# Normalisera alla textfiler till LF i repot
* text=auto eol=lf

# Explicit LF för webbrelaterade filer
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.md   text eol=lf
*.sql  text eol=lf
*.mjs  text eol=lf

# Binärfiler — rör ej
*.png  binary
*.jpg  binary
*.ico  binary
*.woff binary
*.woff2 binary
