# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (e-post för magic links)
RESEND_API_KEY=your-resend-api-key

# 46elks (SMS-inbjudningar)
ELKS_API_USERNAME=your-46elks-username
ELKS_API_PASSWORD=your-46elks-password

# Web Push / VAPID (generera med: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:jonas@rylander.biz
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# Appens URL — används i SMS-länkar och magic-link-redirect
# Lokalt: http://localhost:3000
# Produktion: https://sthlm-triathlon.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
